{
  "name": "press-release-editor/php",
  "description": "Press Release Editor - PHP Implementation",
  "type": "project",
  "require": {
    "php": "^8.5",
    "slim/slim": "^4.13",
    "slim/psr7": "^1.7",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-ctype": "*",
    "aws/aws-sdk-php": "^3.300"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  }
}
